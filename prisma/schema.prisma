generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum BlogPostKind {
  draft
  final
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique @db.VarChar(255)
  displayName    String?          @db.VarChar(255)
  passwordHash   String           @db.VarChar(255)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sessions       Session[]
  blogInputs     BlogInput[]
  blogPosts      BlogPost[]
  blogReferences BlogReference[]
  pipelineItems  PipelineEntry[]
  coiItems       CoiEntry[]

  @@index([createdAt])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @db.VarChar(64)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model BlogInput {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signature         String   @db.VarChar(191)
  topic             String   @db.VarChar(255)
  audience          String   @db.VarChar(255)
  objective         String   @db.VarChar(255)
  tone              String   @db.VarChar(80)
  length            String   @db.VarChar(80)
  cta               String   @db.VarChar(255)
  principlesJson    Json
  selectedPerson    String?  @db.VarChar(255)
  targetMode        String?  @db.VarChar(120)
  styleStrength     String?  @db.VarChar(40)
  styleTitlesJson   Json?
  lengthRangesJson  Json?
  styleThresholdsJson Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, signature])
  @@index([updatedAt])
}

model BlogPost {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           BlogPostKind
  title          String       @db.VarChar(255)
  topic          String       @db.VarChar(255)
  audience       String       @db.VarChar(255)
  objective      String       @db.VarChar(255)
  tone           String       @db.VarChar(80)
  length         String       @db.VarChar(80)
  cta            String       @db.VarChar(255)
  selectedPerson String?      @db.VarChar(255)
  targetMode     String?      @db.VarChar(120)
  outlineText    String       @db.LongText
  finalText      String?      @db.LongText
  isPinned       Boolean      @default(false)
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, kind, updatedAt])
  @@index([userId, isPinned, updatedAt])
}

model BlogReference {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(255)
  type      String   @db.VarChar(50) // "document" or "url"
  content   String?  @db.LongText // for document text
  url       String?  @db.VarChar(500) // for URL links
  topic     String?  @db.VarChar(255) // optional topic/category
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, topic, updatedAt])
  @@index([userId, updatedAt])
}

model PipelineEntry {
  id                    Int       @id @default(autoincrement())
  userId                Int
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospectName          String    @db.VarChar(255)
  businessName          String?   @db.VarChar(255)
  partner               String?   @db.VarChar(255)
  leadStaff             String?   @db.VarChar(255)
  prospectStatus        String    @db.VarChar(80)
  dateLastContact       DateTime?
  address               String?   @db.VarChar(500)
  contactPhone          String?   @db.VarChar(80)
  email                 String?   @db.VarChar(255)
  industry              String?   @db.VarChar(120)
  existingFeeValue      String?   @db.VarChar(120)
  supportStaff          String?   @db.VarChar(255)
  relationshipType      String?   @db.VarChar(80)
  prospectSource        String?   @db.VarChar(120)
  coiInvolved           String?   @db.VarChar(255)
  approachDate          DateTime?
  approachStyle         String?   @db.VarChar(120)
  secureMeeting         Boolean   @default(false)
  quizCompleted         Boolean   @default(false)
  salesStyle            String?   @db.VarChar(80)
  meetingTheme          String?   @db.VarChar(120)
  meetingDate           DateTime?
  followUpMeeting       Boolean   @default(false)
  followUpMeetingDate   DateTime?
  totalNeedsStage       String?   @db.VarChar(80)
  proposalSent          Boolean   @default(false)
  proposalValue         Decimal   @default(0) @db.Decimal(14, 2)
  jobSecured            Boolean   @default(false)
  dateSecured           DateTime?
  jobSecuredValue       Decimal   @default(0) @db.Decimal(14, 2)
  additionalWorkSecured Decimal   @default(0) @db.Decimal(14, 2)
  comments              String?   @db.LongText
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, prospectStatus, updatedAt])
  @@index([userId, leadStaff, updatedAt])
  @@index([userId, partner, updatedAt])
}

model CoiEntry {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coiName                 String   @db.VarChar(255)
  email                   String?  @db.VarChar(255)
  cell                    String?  @db.VarChar(80)
  entity                  String?  @db.VarChar(255)
  position                String?  @db.VarChar(255)
  industry                String?  @db.VarChar(120)
  other                   String?  @db.VarChar(255)
  leadRelationshipPartner String?  @db.VarChar(255)
  relationshipSupport     String?  @db.VarChar(255)
  couldWe                 Int      @default(0)
  howWouldWe              Int      @default(0)
  willWe                  Int      @default(0)
  testReview              Int      @default(0)
  totalReferrals          Int      @default(0)
  totalConverted          Int      @default(0)
  feeValue                Decimal  @default(0) @db.Decimal(14, 2)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, industry, updatedAt])
  @@index([userId, leadRelationshipPartner, updatedAt])
}

model AppConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  configKey String   @db.VarChar(100)
  configVal String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, configKey])
  @@index([userId])
}
